{
  "name": "@storagesdk/adapters",
  "version": "0.7.1",
  "description": "Storage backend adapters for storagesdk. Import the adapter you need via a subpath, e.g. `@storagesdk/adapters/fs`.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./fs": {
      "types": "./dist/fs/index.d.ts",
      "default": "./dist/fs/index.js"
    },
    "./s3": {
      "types": "./dist/s3/index.d.ts",
      "default": "./dist/s3/index.js"
    },
    "./r2": {
      "types": "./dist/r2/index.d.ts",
      "default": "./dist/r2/index.js"
    },
    "./minio": {
      "types": "./dist/minio/index.d.ts",
      "default": "./dist/minio/index.js"
    },
    "./backblaze": {
      "types": "./dist/backblaze/index.d.ts",
      "default": "./dist/backblaze/index.js"
    },
    "./spaces": {
      "types": "./dist/spaces/index.d.ts",
      "default": "./dist/spaces/index.js"
    },
    "./wasabi": {
      "types": "./dist/wasabi/index.d.ts",
      "default": "./dist/wasabi/index.js"
    },
    "./supabase": {
      "types": "./dist/supabase/index.d.ts",
      "default": "./dist/supabase/index.js"
    },
    "./linode": {
      "types": "./dist/linode/index.d.ts",
      "default": "./dist/linode/index.js"
    },
    "./tigris": {
      "types": "./dist/tigris/index.d.ts",
      "default": "./dist/tigris/index.js"
    },
    "./fly": {
      "types": "./dist/fly/index.d.ts",
      "default": "./dist/fly/index.js"
    },
    "./railway": {
      "types": "./dist/railway/index.d.ts",
      "default": "./dist/railway/index.js"
    },
    "./azure": {
      "types": "./dist/azure/index.d.ts",
      "default": "./dist/azure/index.js"
    },
    "./gcs": {
      "types": "./dist/gcs/index.d.ts",
      "default": "./dist/gcs/index.js"
    },
    "./vercel": {
      "types": "./dist/vercel/index.d.ts",
      "default": "./dist/vercel/index.js"
    },
    "./github": {
      "types": "./dist/github/index.d.ts",
      "default": "./dist/github/index.js"
    },
    "./freestyle": {
      "types": "./dist/freestyle/index.d.ts",
      "default": "./dist/freestyle/index.js"
    },
    "./webdav": {
      "types": "./dist/webdav/index.d.ts",
      "default": "./dist/webdav/index.js"
    },
    "./test-suite": {
      "types": "./dist/test-suite.d.ts",
      "default": "./dist/test-suite.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "publint": "publint",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "storage",
    "storagesdk",
    "adapter",
    "filesystem",
    "s3",
    "r2",
    "minio",
    "tigris",
    "fly",
    "railway",
    "azure",
    "gcs",
    "vercel-blob",
    "github",
    "freestyle",
    "webdav",
    "nextcloud",
    "owncloud",
    "backblaze",
    "b2",
    "digitalocean",
    "spaces",
    "wasabi",
    "supabase",
    "linode"
  ],
  "author": "",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/storagesdk/storagesdk.git",
    "directory": "packages/adapters"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@storagesdk/core": "workspace:*"
  },
  "peerDependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/lib-storage": "^3.0.0",
    "@aws-sdk/s3-presigned-post": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@azure/storage-blob": "^12.0.0",
    "@google-cloud/storage": "^7.0.0",
    "@octokit/rest": "^21.0.0",
    "freestyle": "^0.1.63",
    "@tigrisdata/storage": "^3.11.0",
    "@vercel/blob": "^2.3.0",
    "vitest": "^4.0.0",
    "webdav": "^5.10.0"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-s3": {
      "optional": true
    },
    "@aws-sdk/lib-storage": {
      "optional": true
    },
    "@aws-sdk/s3-presigned-post": {
      "optional": true
    },
    "@aws-sdk/s3-request-presigner": {
      "optional": true
    },
    "@azure/storage-blob": {
      "optional": true
    },
    "@google-cloud/storage": {
      "optional": true
    },
    "@octokit/rest": {
      "optional": true
    },
    "freestyle": {
      "optional": true
    },
    "@tigrisdata/storage": {
      "optional": true
    },
    "@vercel/blob": {
      "optional": true
    },
    "vitest": {
      "optional": true
    },
    "webdav": {
      "optional": true
    }
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/lib-storage": "^3.1053.0",
    "@aws-sdk/s3-presigned-post": "^3.1053.0",
    "@aws-sdk/s3-request-presigner": "^3.1053.0",
    "@azure/storage-blob": "^12.31.0",
    "@google-cloud/storage": "^7.19.0",
    "@octokit/rest": "^21.1.1",
    "@tigrisdata/storage": "^3.11.0",
    "@vercel/blob": "^2.4.0",
    "freestyle": "^0.1.63",
    "webdav": "^5.10.0"
  }
}
