{
  "name": "@storagesdk/adapters",
  "version": "0.0.0",
  "description": "Storage backend adapters for storagesdk. Import the adapter you need via a subpath, e.g. `@storagesdk/adapters/fs`.",
  "type": "module",
  "exports": {
    "./fs": {
      "types": "./dist/fs/index.d.ts",
      "default": "./dist/fs/index.js"
    },
    "./s3": {
      "types": "./dist/s3/index.d.ts",
      "default": "./dist/s3/index.js"
    },
    "./tigris": {
      "types": "./dist/tigris/index.d.ts",
      "default": "./dist/tigris/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "publint": "publint",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "storage",
    "storagesdk",
    "adapter",
    "filesystem",
    "s3",
    "tigris"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tigrisdata/storagesdk.git",
    "directory": "packages/adapters"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@storagesdk/core": "workspace:*"
  },
  "peerDependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/lib-storage": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@tigrisdata/storage": "^3.6.0"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-s3": {
      "optional": true
    },
    "@aws-sdk/lib-storage": {
      "optional": true
    },
    "@aws-sdk/s3-request-presigner": {
      "optional": true
    },
    "@tigrisdata/storage": {
      "optional": true
    }
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/lib-storage": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@tigrisdata/storage": "^3.6.0"
  }
}
