---
import AdapterMarquee from '../components/AdapterMarquee';
import AdapterSwitcher from '../components/AdapterSwitcher';
import CustomAdapterSection from '../components/CustomAdapterSection';
import Features from '../components/Features';
import FinalCta from '../components/FinalCta';
import Footer from '../components/Footer';
import Hero from '../components/Hero';
// CLI page/section commented out until @storagesdk/cli ships.
// import CliSection from '../components/CliSection';
import InstallSection from '../components/InstallSection';
import Nav from '../components/Nav';
import OneVerb from '../components/OneVerb';
import Primitives from '../components/Primitives';
import Base from '../layouts/Base.astro';
---
<Base
  title="A fully-featured TypeScript SDK for storage — one portable interface across different providers"
  description="A multi-provider TypeScript SDK for object storage across Tigris, S3, R2, GCS, Azure, Vercel Blob and many more — with snapshots and forks as core operations."
>
  <Nav client:load transition:persist="nav" />
  <Hero client:load />
  <AdapterMarquee />
  <Primitives client:load />
  <AdapterSwitcher client:load />
  <OneVerb client:load />
  <Features />
  <CustomAdapterSection client:load />
  {/* CliSection hidden from landing until @storagesdk/cli ships. */}
  {/* <CliSection client:load /> */}
  <InstallSection client:load />
  <FinalCta />
  <Footer transition:persist="footer" />
</Base>
