---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import { inlineThemeScript } from '../lib/theme';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---
<!doctype html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />

  <link rel="icon" type="image/svg+xml" href="/logo/storagesdk-mark-light.svg" media="(prefers-color-scheme: light)" />
  <link rel="icon" type="image/svg+xml" href="/logo/storagesdk-mark-white.svg" media="(prefers-color-scheme: dark)" />

  <link rel="preload" href="/fonts/Geist.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/GeistMono.woff2" as="font" type="font/woff2" crossorigin />

  {/* Read persisted theme before first paint to avoid a flash. */}
  <script is:inline set:html={inlineThemeScript} />

  {/* SPA-style page swaps so the Nav and Footer don't re-mount on
      every navigation. Marked elements with transition:persist below
      keep the same DOM node across routes. */}
  <ClientRouter />
</head>
<body>
  <slot />
</body>
</html>
